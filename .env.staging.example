ENV=staging
PORTAL=customer
CUSTOMER_BASE_URL=https://staging-app.webvio.in/
VENDOR_BASE_URL=https://staging-vendor.webvio.in/
ADMIN_BASE_URL=https://staging-admin.webvio.in/
API_BASE_URL=https://staging-api.angelecho.ai/v1
HEADLESS=true
BROWSER=chromium
DEFAULT_TIMEOUT_MS=15000
SLOW_MO_MS=0
TRACE_ON_FAILURE=true
VIDEO_ON_FAILURE=false
CUSTOMER_EMAIL=
CUSTOMER_PASSWORD=
VENDOR_EMAIL=
VENDOR_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vendor portal override example:
# PORTAL=vendor
# VENDOR_EMAIL=
# VENDOR_PASSWORD=
# AUTHENTICATED_SHELL_TEXT=Vendor Portal
